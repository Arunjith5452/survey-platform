# Environment Variables for Backend
# Copy this file to .env and fill in your actual values

# Node Environment (development or production)
NODE_ENV=development

# MongoDB Connection String
# For local: mongodb://localhost:27017/survey-form
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/survey-form
MONGODB_URI=mongodb://localhost:27017/survey-form

# JWT Secret (Use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Token Expiration
JWT_EXPIRES_IN=24h

# Server Port
PORT=5000

# CORS Origin (Frontend URL in production)
# For development, you can use * or http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Admin Credentials (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
